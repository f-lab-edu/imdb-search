{
  "name": "imdb-search",
  "version": "1.0.0",
  "description": "영상 콘텐츠의 데이터와 사용자 평점을 제공하는 IMDb의 공개 데이터를 활용한 검색 시스템",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
