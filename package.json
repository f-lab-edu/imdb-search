  "type": "module",
  "bugs": {
    "url": "https://github.com/f-lab-edu/imdb-search/issues"
  },
  "homepage": "https://github.com/f-lab-edu/imdb-search#readme",
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opensearch-project/opensearch": "^3.5.1",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
