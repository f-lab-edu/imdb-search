    "test:utils": "npm test -- tests/utils/",
    "test:task": "npm test -- tests/workers/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f-lab-edu/imdb-search.git"
  },
  "keywords": [],
