{
  "name": "imdb-search",
  "version": "1.0.0",
  "description": "영상 콘텐츠의 데이터와 사용자 평점을 제공하는 IMDb의 공개 데이터를 활용한 검색 시스템",
  "main": "dist/index.js",
  "bin": {
    "imdbs": "./dist/index.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx src/index.ts run",
    "dev:pipeline": "tsx src/index.ts pipeline",
    "dev:index": "tsx src/index.ts index",
    "dev:api": "tsx src/index.ts api",
    "clean": "rm -rf dist",
    "build": "tsc && cp src/db/mysql/schema.sql dist/db/mysql/schema.sql && chmod +x dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --detectOpenHandles",
    "test:db": "npm test -- tests/db/",
    "test:utils": "npm test -- tests/utils/",
    "test:task": "npm test -- tests/worker/",
    "test:worker": "npm run build && NODE_OPTIONS='--experimental-vm-modules' jest --detectOpenHandles dist/tests/worker/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f-lab-edu/imdb-search.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/f-lab-edu/imdb-search/issues"
  },
  "homepage": "https://github.com/f-lab-edu/imdb-search#readme",
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "@types/node-cron": "^3.0.11",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opensearch-project/opensearch": "^3.5.1",
    "@types/express": "^5.0.6",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mysql2": "^3.16.2",
    "node-cron": "^4.2.1",
    "redis": "^5.10.0"
  }
}
